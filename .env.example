DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sckey
DB_USER=postgres
DB_PASS=

# Or use one connection string instead:
# DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/sckey

SCKEY_API_BASE=https://api.sckey.net
# Optional. Prefer passing Authorization from the client request instead.
SCKEY_BEARER_TOKEN=

# Optional image rendering settings. If empty, the service tries common Chrome/Edge paths.
PUPPETEER_EXECUTABLE_PATH=
STATUS_IMAGE_FOOTER=ClouderyStudio
STATUS_IMAGE_SCALE=1
